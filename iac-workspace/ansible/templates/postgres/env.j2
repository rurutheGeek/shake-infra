# PostgreSQL Credentials
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ db_name }}

# Read-only User
PKDB_READER_USER={{ db_user_reader }}
PKDB_READER_PASSWORD={{ db_password_reader }}

# Read-Write User
PKDB_EDITOR_USER={{ db_user_editor }}
PKDB_EDITOR_PASSWORD={{ db_password_editor }}

# Cloudflare R2 (Backup)
CF_BUCKET_NAME={{ cf_bucket_name }}
CF_ACCOUNT_ID={{ cf_account_id }}
CF_ACCESS_KEY={{ cf_access_key }}
CF_SECRET_KEY={{ cf_secret_key }}

# PostgreSQL UID/GID (Ansible Managed)
PG_UID={{ postgres_system_user.uid }}
PG_GID={{ postgres_system_user.group }}