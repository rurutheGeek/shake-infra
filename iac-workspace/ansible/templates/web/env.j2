DB_USER={{ db_user_reader }}
DB_HOST={{ db_host }}
DB_NAME={{ db_name }}
DB_PASSWORD={{ db_password_reader }}
DB_PORT={{ db_port }}

# shake_web サイト用 DB（quiz_rankings 等）。host/port は db_* を既定で流用。
SHAKEWEB_DB_HOST={{ shakeweb_db_host | default(db_host) }}
SHAKEWEB_DB_PORT={{ shakeweb_db_port | default(db_port) }}
SHAKEWEB_DB_NAME={{ shakeweb_db_name | default('shakeweb') }}
SHAKEWEB_DB_READER_USER={{ shakeweb_db_user_reader | default('shakeweb_reader') }}
SHAKEWEB_DB_READER_PASSWORD={{ shakeweb_db_password_reader }}
SHAKEWEB_DB_EDITOR_USER={{ shakeweb_db_user_editor | default('shakeweb_editor') }}
SHAKEWEB_DB_EDITOR_PASSWORD={{ shakeweb_db_password_editor }}

# pkhack（ポケモンクイズ）専用 DB（quiz_rankings）。host/port は db_* を既定で流用。
# パスワードは Vault に pkhack_db_password_* を追加するまで空文字（接続は未確立）。
PKHACK_DB_HOST={{ pkhack_db_host | default(db_host) }}
PKHACK_DB_PORT={{ pkhack_db_port | default(db_port) }}
PKHACK_DB_NAME={{ pkhack_db_name | default('pkhack') }}
PKHACK_DB_READER_USER={{ pkhack_db_user_reader | default('pkhack_reader') }}
PKHACK_DB_READER_PASSWORD={{ pkhack_db_password_reader | default('') }}
PKHACK_DB_EDITOR_USER={{ pkhack_db_user_editor | default('pkhack_editor') }}
PKHACK_DB_EDITOR_PASSWORD={{ pkhack_db_password_editor | default('') }}