# このファイルはAnsible Vaultで暗号化されるべき機密情報を定義するためのサンプルファイルです。
# 実際の使用時は「vault.yml」というファイル名でコピーし、Ansible Vaultで暗号化してください。
# `ansible-vault encrypt vault.yml`

# ==========================================
# PostgreSQL
# ==========================================
postgres_user:          "YOUR_POSTGRES_SUPERUSER"
postgres_password:      "YOUR_POSTGRES_SUPERUSER_PASSWORD"
db_password_reader:     "YOUR_PKDB_READER_PASSWORD"
db_password_editor:     "YOUR_PKDB_EDITOR_PASSWORD"

# ==========================================
# Minecraft
# ==========================================
mc_rcon_password: "YOUR_MINECRAFT_RCON_PASSWORD"

# ==========================================
# Cloudflare R2 / API
# ==========================================
# R2バケット操作用APIキー（バックアップ・ubsleepy・restore テストで使用）
cf_access_key: "YOUR_R2_ACCESS_KEY_ID"
cf_secret_key: "YOUR_R2_SECRET_ACCESS_KEY"

# Cloudflare API キー（ubsleepy アプリ内部で使用）
cf_api_key: "YOUR_CF_API_KEY_HASH"

# ==========================================
# Discord
# ==========================================
# ubsleepy Discord Bot トークン
ubsleepy_discord_token: "YOUR_DISCORD_BOT_TOKEN"

# バックアップ通知・SSL期限アラート等の汎用Webhook URL
ubsleepy_backup_discord_webhook: "https://discord.com/api/webhooks/YOUR_WEBHOOK_URL"

# ==========================================
# オプション（コメントアウトを外して使用）
# ==========================================

# SSL証明書期限アラート専用Webhook（未設定時は ubsleepy_backup_discord_webhook を使用）
# ssl_cert_discord_webhook: "https://discord.com/api/webhooks/YOUR_SSL_ALERT_WEBHOOK"
